{
  "rewrites": [
    {
      "source": "/pre/:path*",
      "destination": "/pre/index.html"
    }
  ],
  "headers": [
    {
      "source": "/credit-card-tracker/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "max-age=0, no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
}
